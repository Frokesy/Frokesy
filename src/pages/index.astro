---
import "../styles/global.css";
import InteractiveNav from "../components/InteractiveNav";
import MotionReveal from "../components/MotionReveal";

const navigation = [
  { href: "#about", label: "About", number: "01" },
  { href: "#experience", label: "Experience", number: "02" },
  { href: "#projects", label: "Projects", number: "03" },
  { href: "#contact", label: "Contact", number: "04" },
];

const experience = [
  {
    title: "Web Developer",
    company: "WHEXcosystem",
    type: "Freelance",
    duration: "2022 - 2024",
    summary:
      "Improved product UI, maintained the production codebase, and shipped growth-focused frontend updates across client-facing experiences.",
    impact: [
      "Partnered with design to improve UX quality and visual consistency.",
      "Integrated a token sale widget with an external team to support launch goals.",
      "Implemented SEO improvements that increased discoverability and organic traffic.",
    ],
    stack: ["Next.js", "Tailwind CSS", "JavaScript"],
  },
  {
    title: "Frontend Developer",
    company: "Dexterpro",
    type: "Contract",
    duration: "2023",
    summary:
      "Translated design concepts into polished interfaces with a strong focus on precision, usability, and delivery speed.",
    impact: [
      "Built responsive interfaces from design files with near pixel-perfect accuracy.",
      "Tested and iterated on key user flows to improve reliability before handoff.",
      "Delivered production-ready frontend work within tight client timelines.",
    ],
    stack: ["React", "TypeScript", "Tailwind CSS"],
  },
  {
    title: "Frontend Developer",
    company: "Luxuriant Flower Schools",
    type: "Full-time",
    duration: "2020 - 2021",
    summary:
      "Worked across product and engineering to ship a responsive school platform and a student record management experience.",
    impact: [
      "Built responsive frontend experiences for students, parents, and staff.",
      "Collaborated with backend engineers to integrate APIs into the record system.",
      "Maintained and debugged the codebase to support ongoing operational needs.",
    ],
    stack: ["HTML", "CSS", "JavaScript", "PHP"],
  },
];

const projectThemes = [
  {
    title: "Interaction-First Product Surfaces",
    description:
      "Interfaces that turn complex product states into responsive, intuitive user feedback.",
  },
  {
    title: "Motion-Driven Marketing Experiences",
    description:
      "Fast landing pages and campaign sites where animation strengthens storytelling and conversion.",
  },
  {
    title: "Design Systems With Frontend Discipline",
    description:
      "Reusable UI patterns that stay visually sharp while remaining maintainable in real-world codebases.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <title>Ayanfeoluwa Akindele | Frontend Interaction Engineer</title>
    <meta
      name="description"
      content="Portfolio of Ayanfeoluwa Akindele, a frontend interaction engineer crafting sleek, responsive, and high-performance digital experiences."
    />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="site-mark" href="#top" aria-label="Go to top">
          <span class="site-mark__eyebrow">Ayanfeoluwa Akindele</span>
          <span class="site-mark__title">Frontend Interaction Engineer</span>
        </a>

        <InteractiveNav items={navigation} client:load />
      </header>

      <main id="top">
        <section class="hero section">
          <p class="section-kicker">Available for product teams, startups, and premium web experiences</p>
          <div class="hero__content">
            <MotionReveal className="hero__copy" client:load>
              <div class="hero__eyebrow-group">
                <p class="hero__eyebrow">Frontend interaction engineer</p>
                <p class="hero__eyebrow">5 years of professional experience</p>
              </div>
              <h1>
                I design and build <em>interaction-rich</em> interfaces that stay fast, sharp, and unmistakably intentional.
              </h1>
              <p class="hero__lede">
                I translate visual direction into polished frontend systems with a
                strong eye for motion, UI behavior, and implementation detail.
                My work blends product thinking, visual precision, and
                performance discipline to create experiences people can feel.
              </p>

              <ul class="hero__signal-list" aria-label="Core strengths">
                <li>Motion systems that support hierarchy and feedback</li>
                <li>Responsive UI engineered for product and marketing surfaces</li>
                <li>Frontend craft that balances polish, speed, and maintainability</li>
              </ul>

              <div class="hero__actions">
                <a class="button button--primary" href="#projects">View selected work</a>
                <a class="button button--secondary" href="#contact">Get in touch</a>
              </div>
            </MotionReveal>

            <MotionReveal className="hero__stage" delay={0.12} y={36} client:load>
              <div class="hero-stage">
                <div class="hero-stage__frame">
                  <div class="hero-stage__glow"></div>
                  <div class="hero-stage__grid"></div>
                  <div class="hero-stage__orb hero-stage__orb--primary"></div>
                  <div class="hero-stage__orb hero-stage__orb--secondary"></div>
                  <div class="hero-stage__object">
                    <div class="hero-stage__object-core"></div>
                    <div class="hero-stage__object-ring hero-stage__object-ring--one"></div>
                    <div class="hero-stage__object-ring hero-stage__object-ring--two"></div>
                  </div>
                  <div class="hero-stage__badge">Future `three.js` signature interaction</div>
                </div>
              </div>

              <div class="hero__meta-grid">
                <div class="info-card">
                  <p class="info-card__label">Primary focus</p>
                  <p>Interaction design, frontend systems, motion direction, and polished responsive UI.</p>
                </div>
                <div class="info-card">
                  <p class="info-card__label">Working principle</p>
                  <p>Every effect should clarify, guide, or reward. Never just decorate.</p>
                </div>
              </div>
            </MotionReveal>
          </div>
        </section>

        <section class="section section-grid" id="about">
          <MotionReveal className="section-heading" client:visible>
            <p class="section-index">01</p>
            <p class="section-kicker">About</p>
            <h2>Engineering interactions with clarity and <em>restraint</em>.</h2>
          </MotionReveal>

          <MotionReveal className="section-body section-panel prose-flow" delay={0.08} client:visible>
            <p>
              My work sits at the intersection of visual craft and frontend
              implementation. I care about layout rhythm, interface feedback, and
              the tiny details that make a product feel considered.
            </p>
            <p>
              Over the last five years, I have worked across freelance,
              contract, and product-focused roles, building responsive web
              experiences for startups, clients, and teams that needed design
              precision without sacrificing maintainability.
            </p>
            <p>
              This next version of my portfolio is designed to reflect that
              strength more clearly: not just what I have built, but how I think
              about interaction, motion, and frontend quality.
            </p>
          </MotionReveal>
        </section>

        <section class="section section-grid" id="experience">
          <MotionReveal className="section-heading" client:visible>
            <p class="section-index">02</p>
            <p class="section-kicker">Experience</p>
            <h2>A progression shaped by UI craft, collaboration, and shipping.</h2>
          </MotionReveal>

          <MotionReveal className="section-body stack-lg" delay={0.08} client:visible>
            {
              experience.map((role) => (
                <article class="timeline-card">
                  <div class="timeline-card__header">
                    <div>
                      <p class="timeline-card__duration">{role.duration}</p>
                      <h3>{role.title}</h3>
                    </div>
                    <p class="timeline-card__company">
                      {role.company} <span>{role.type}</span>
                    </p>
                  </div>

                  <p class="timeline-card__summary">{role.summary}</p>

                  <ul class="impact-list">
                    {role.impact.map((item) => <li>{item}</li>)}
                  </ul>

                  <ul class="tag-list" aria-label={`${role.title} technologies`}>
                    {role.stack.map((item) => <li>{item}</li>)}
                  </ul>
                </article>
              ))
            }
          </MotionReveal>
        </section>

        <section class="section section-grid" id="projects">
          <MotionReveal className="section-heading" client:visible>
            <p class="section-index">03</p>
            <p class="section-kicker">Projects</p>
            <h2>Selected work will be curated around interaction quality and frontend depth.</h2>
          </MotionReveal>

          <MotionReveal className="section-body project-grid" delay={0.08} client:visible>
            {
              projectThemes.map((project) => (
                <article class="project-card">
                  <p class="project-card__eyebrow">Case study track</p>
                  <h3>{project.title}</h3>
                  <p>{project.description}</p>
                </article>
              ))
            }
          </MotionReveal>
        </section>

        <section class="section section-grid" id="contact">
          <MotionReveal className="section-heading" client:visible>
            <p class="section-index">04</p>
            <p class="section-kicker">Contact</p>
            <h2>Available for product teams, freelance collaborations, and thoughtful frontend work.</h2>
          </MotionReveal>

          <MotionReveal className="section-body contact-panel" delay={0.08} client:visible>
            <p>
              If you are building a product, campaign, or interface-heavy web
              experience and want someone who cares deeply about how it feels in
              motion, let’s talk.
            </p>

            <div class="contact-links">
              <a href="mailto:hello@ayanfeoluwa.dev">hello@ayanfeoluwa.dev</a>
              <a href="https://github.com/Frokesy" target="_blank" rel="noreferrer">GitHub</a>
              <a
                href="https://www.linkedin.com/in/ayanfeoluwa-akindele-5838b0233/"
                target="_blank"
                rel="noreferrer"
              >
                LinkedIn
              </a>
              <a href="https://twitter.com/_frokes" target="_blank" rel="noreferrer">X / Twitter</a>
            </div>
          </MotionReveal>
        </section>
      </main>
    </div>
  </body>
</html>
